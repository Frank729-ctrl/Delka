APP_ENV=development
PORT=8000

SECRET_MASTER_KEY=fd-delka-mk-replace-this

DB_HOST=localhost
DB_PORT=3306
DB_NAME=delkaai
DB_USER=root
DB_PASSWORD=

DATABASE_URL=

# ── Groq Provider ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_replace_with_your_groq_key

# ── Per-Task Model Assignment ──────────────────────────────────────────────────
CV_PRIMARY_PROVIDER=groq
CV_PRIMARY_MODEL=llama-3.3-70b-versatile
CV_FALLBACK_PROVIDER=ollama
CV_FALLBACK_MODEL=llama3.1

LETTER_PRIMARY_PROVIDER=groq
LETTER_PRIMARY_MODEL=llama-3.3-70b-versatile
LETTER_FALLBACK_PROVIDER=ollama
LETTER_FALLBACK_MODEL=llama3.1

SUPPORT_PRIMARY_PROVIDER=groq
SUPPORT_PRIMARY_MODEL=llama-3.1-8b-instant
SUPPORT_FALLBACK_PROVIDER=ollama
SUPPORT_FALLBACK_MODEL=mistral

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_STREAM_TIMEOUT_SECONDS=60

ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

HMAC_TIMESTAMP_TOLERANCE_SECONDS=300

RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_IP_MINUTE=60
RATE_LIMIT_BURST_PER_SECOND=5

LLM_MAX_RETRIES=2
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

ALLOWED_ORIGINS=*
METRICS_PERSIST_INTERVAL_SECONDS=300
